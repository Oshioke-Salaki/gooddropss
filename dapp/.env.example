# ─────────────────────────────────────────────────────────────────────────────
# GoodDrops dApp — environment variables
#
# Copy to `.env.local` and fill in. NEXT_PUBLIC_* are exposed to the browser
# (safe to be public); everything else is server-only and must stay secret.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core data & storage (REQUIRED) ───────────────────────────────────────────
# Goldsky/The Graph endpoint the app reads drops from.
NEXT_PUBLIC_SUBGRAPH_URL="https://api.goldsky.com/api/public/.../gn"

# Upstash Redis — backs landmarks, suggestions, reports/moderation, push subs,
# streaks, riddles, campaigns. Without it those features degrade gracefully.
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# ── Auth (REQUIRED) ───────────────────────────────────────────────────────────
# Magic email/OTP sign-in (publishable key).
NEXT_PUBLIC_MAGIC_KEY="pk_live_..."

# Admin console gate (/admin/*). Server-only — NOT NEXT_PUBLIC. Pick a strong
# value:  openssl rand -base64 24
ADMIN_PASSWORD="change-me-strong-password"

# Extra admin WALLETS (comma-separated, lowercase) on top of the built-ins.
# Used by both the client UI gate and server-side landmark writes. Optional.
NEXT_PUBLIC_ADMIN_ADDRESSES="0xabc...,0xdef..."

# ── Claim proof signing (REQUIRED for GPS claims) ────────────────────────────
# Private key the server uses to sign claim proofs. Server-only, keep secret.
GPS_SIGNER_KEY="0xyour-gps-signer-private-key"

# ── Web Push / notifications (REQUIRED for push, nearby alerts, reminders) ───
# Generate a keypair once with:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BM...public..."
VAPID_PRIVATE_KEY="...private..."
VAPID_EMAIL="you@example.com"

# Shared secret protecting the internal notify endpoint (/api/push/notify). The
# webhook and the re-verify cron send it as the x-internal-secret header.
# Pick any high-entropy value:  openssl rand -hex 32
INTERNAL_WEBHOOK_SECRET="change-me-internal-secret"

# ── Re-verify reminder cron (REQUIRED for that feature) ──────────────────────
# Secret protecting /api/cron/reverify. YOU generate this — any random string:
#   openssl rand -hex 32
# Set the SAME value in the Vercel project env; Vercel Cron automatically sends
# it as the request's `Authorization: Bearer <CRON_SECRET>` header. The endpoint
# fails closed (401) if this isn't set, so the cron simply won't run.
CRON_SECRET="change-me-cron-secret"

# How many subscribers the cron scans per run (rotates across runs). Optional;
# defaults to 120. Lower it if you hit serverless time limits.
# REVERIFY_BATCH="120"

# ── Optional cosmetics ───────────────────────────────────────────────────────
# Canonical site URL (SEO/metadata). Defaults to https://gooddrops.xyz.
# NEXT_PUBLIC_SITE_URL="https://gooddrops.xyz"

# G$ → USD display rate override. Defaults to 0.00003.
# NEXT_PUBLIC_GDOLLAR_USD="0.00003"
