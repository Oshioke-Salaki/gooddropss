{
  "name": "gooddrops-contracts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:celo": "hardhat run scripts/deploy.js --network celo",
    "deploy:alfajores": "hardhat run scripts/deploy.js --network alfajores",
    "upgrade:celo": "hardhat run scripts/upgrade.js --network celo",
    "upgrade:alfajores": "hardhat run scripts/upgrade.js --network alfajores",
    "verify:celo": "hardhat verify --network celo",
    "flatten": "hardhat flatten contracts/GoodDrops.sol > FlatGoodDrops.sol"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/hardhat-upgrades": "^3.0.0",
    "hardhat": "^2.22.0",
    "dotenv": "^16.0.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.0"
  }
}
